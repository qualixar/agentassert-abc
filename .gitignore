# Python-generated files
__pycache__/
*.py[cod]
*.pyo
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv/
venv/

# Environment / secrets
.env
.env.*
*.env

# Test/lint artifacts
.coverage
htmlcov/
.hypothesis/
